# SmartSalai Edge-Sentinel — Configuration Template (v1.2.2-Hardened)
# Copy this to '.env' and fill in the values below.

# --- [CORE SECURITY] ---
# A secure 32+ character string for Dashboard access.
# Required in production startup; no fallback auto-generation.
DASHBOARD_SECRET_KEY=

# A secure 32+ character string for CSRF protection.
# Required in production startup.
CSRF_SECRET_KEY=

# --- [FIREBASE BACKEND] ---
# Your Firebase Project ID (found in Project Settings)
FIREBASE_PROJECT_ID=

# Path to your Firebase serviceAccountKey.json (Plaintext) 
# or encrypted .enc file.
FIREBASE_PRIVATE_KEY_PATH=config/firebase_credentials.json

# --- [RECOVERY & LOGGING] ---
# Set to 'DEBUG' for verbose swarm logs
LOG_LEVEL=INFO

# --- [HARDWARE GOVERNANCE] ---
# Maximum safe GPU temperature for the RTX 3050 before throttling starts
THERMAL_THRESHOLD_C=78
