# Primary production API
API_PORT=8000
API_USE_HTTPS=false
API_REQUIRE_HTTPS_REDIRECT=false
API_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Auth & signatures
CSRF_SECRET_KEY=replace-with-32-plus-char-secret
DASHBOARD_SECRET_KEY=replace-with-32-plus-char-secret
INGEST_HMAC_SECRET=replace-with-32-plus-char-secret
FLEET_API_KEYS=replace-with-fleet-token-1,replace-with-fleet-token-2

# Data
EDGE_SPATIAL_DB_PATH=edge_spatial.db

# Payment webhook (optional for non-payment deployments)
RAZORPAY_WEBHOOK_SECRET=replace-with-webhook-secret

# Optional TLS (required when API_USE_HTTPS=true)
# API_TLS_CERT_PATH=/absolute/path/to/fullchain.pem
# API_TLS_KEY_PATH=/absolute/path/to/privkey.pem
