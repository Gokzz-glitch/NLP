# .env.example — SmartSalai Edge-Sentinel environment configuration
# Copy this file to .env and fill in your credentials.
#   cp .env.example .env
# NEVER commit .env to git (it is in .gitignore).

# ===========================================================================
# ERR-001 — Vision model (YOLOv8-nano ONNX for Indian traffic signs)
# ===========================================================================

# Roboflow API key (get from https://roboflow.com → Account → API Keys)
# Used by: scripts/download_models.py --source roboflow
ROBOFLOW_API_KEY=

# HuggingFace token (optional; required only for gated HF repos)
# Used by: scripts/download_models.py --source hf
HF_TOKEN=

# Override the ONNX model path (default: models/vision/indian_traffic_yolov8.onnx)
# VISION_MODEL_PATH=models/vision/indian_traffic_yolov8.onnx

# Override detection confidence threshold (default: 0.45)
# VISION_CONF_THRESHOLD=0.45

# Force mock mode (set to 1 in CI / unit tests)
# VISION_MOCK_MODE=0

# ===========================================================================
# ERR-002 — Bhashini Tamil TTS
# ===========================================================================

# Bhashini / ULCA user ID and API key.
# Register at https://bhashini.gov.in → My Account → API Keys.
# Once set, AcousticUI will use real Tamil synthesis instead of pyttsx3 English.
BHASHINI_USER_ID=
BHASHINI_API_KEY=

# ===========================================================================
# Live camera / real-time testing
# ===========================================================================

# Set to 1 to enable the live camera stream and inference background task.
# Use live_runner.py (recommended) or set manually before starting uvicorn.
# LIVE_CAMERA_ENABLED=0

# Single-camera mode — legacy / simple webcam (device index, default 0).
# CAMERA_INDEX=0

# Multi-camera / 360° rig mode (overrides CAMERA_INDEX when set).
#   CAMERA_INDICES : comma-separated cv2 device indices, one per camera.
#   CAMERA_DIRECTIONS : matching direction labels (front/rear/left/right or custom).
#   Each camera gets its own MJPEG stream at /video_feed/<direction>.
#   Example — 4-camera 360° dashcam rig:
# CAMERA_INDICES=0,1,2,3
# CAMERA_DIRECTIONS=front,rear,left,right
#   Example — dual webcam (front + rear only):
# CAMERA_INDICES=0,1
# CAMERA_DIRECTIONS=front,rear

# Starting GPS coordinates (decimal degrees).
# Updated at runtime via POST /api/v1/gps/update or live_runner.py --gps-lat/lon.
# Default: Chennai, Tamil Nadu
# GPS_LAT=13.0827
# GPS_LON=80.2707



# ===========================================================================
# Paths (override defaults if needed)
# ===========================================================================

# VISION_MODELS_DIR=models/vision
# LLM_MODELS_DIR=models/llm
