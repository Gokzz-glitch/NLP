# Large Video / Camera Footage
# NOTE: Do NOT use PowerShell's >> operator to add lines here — it writes UTF-16,
# which Git cannot parse. Instead use: Add-Content -Encoding UTF8 .gitignore "*.mp4"
# or simply edit this file directly in VS Code / Notepad.
*.mp4
*.ts
*.avi
*.mov
*.mkv
*.wmv
*.flv
*.webm
*.m4v
*.mpg
*.mpeg
360camvideo

